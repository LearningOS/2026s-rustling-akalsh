# opencamp-rustlings/.envrc

# 1. 设置本地 Cargo/Rustup 目录（完全隔离）
export CARGO_HOME="${PWD}/.cargo"
export PATH="${CARGO_HOME}/bin:${PATH}"

# 2. 确保目录存在
mkdir -p "${CARGO_HOME}/bin"

# 3. 自动创建 Cargo 配置（清华镜像 + 稀疏索引）
if [[ ! -f "${CARGO_HOME}/config.toml" ]]; then
    cat > "${CARGO_HOME}/config.toml" << 'EOF'
# 清华镜像配置 - 稀疏索引（sparse）加速
[source.crates-io]
replace-with = 'mirror'

[source.mirror]
registry = "sparse+https://mirrors.tuna.tsinghua.edu.cn/crates.io-index/"

[registries.mirror]
index = "sparse+https://mirrors.tuna.tsinghua.edu/crates.io-index/"

# 优化配置
[net]
git-fetch-with-cli = false    # 使用 libgit2 而不是 git 命令
retry = 3                     # 网络失败重试次数

[http]
timeout = 60                  # HTTP 超时时间（秒）
multiplexing = true          # HTTP/2 多路复用
EOF
    echo "✓ 已创建 ${CARGO_HOME}/config.toml（清华镜像）"
fi

# 4. 显示环境信息
echo ""
echo "=========================================="
echo "Rustlings 开发环境已激活"
echo "=========================================="
echo "CARGO_HOME:  ${CARGO_HOME}"
echo "RUSTUP_HOME: ${RUSTUP_HOME}"
echo "镜像源:      清华大学 TUNA (sparse)"
echo "=========================================="
echo ""
echo "可用命令："
echo "  cargo install --force --path .  # 安装 rustlings 5.5.1"
echo "  rustlings watch                  # 运行练习（旧版 5.x 方式）"
echo "  rustlings list                   # 查看进度"
echo ""

